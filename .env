#
# This file is loaded each time the automated E2E test suite is run.
# It sets a bunch of envvars that drive the behaviour of the automated E2E test suite.
#

# The target environment that will be tested.
# Possible values are dev and qa
TEST_ENVIRONMENT=dev

#
# Ozone HSC URLs for dev and qa environments.
#

# OpenMRS
O3_URL_DEV=https://oz-hsc-dev.mekomsolutions.net 
O3_URL_QA=

# Odoo
ODOO_URL_DEV=https://erp.oz-hsc-dev.mekomsolutions.net
ODOO_URL_QA=

#
# Ozone HSC credentials
#

# Ozone test user credentials
O3_USERNAME=testuser
O3_PASSWORD=User1234
